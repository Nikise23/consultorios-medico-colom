# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos?schema=public

# OPCIÓN 1: PostgreSQL Local (si tienes PostgreSQL instalado localmente)
# DATABASE_URL="postgresql://postgres:tu_contraseña@localhost:5432/historias_clinicas?schema=public"

# OPCIÓN 2: Neon.tech (PostgreSQL Serverless - RECOMENDADO para desarrollo)
# DATABASE_URL="postgresql://usuario:password@host/database?sslmode=require"
# Obtén tu connection string desde el dashboard de Neon.tech

# OPCIÓN 3: Render (si usas la base de datos de Render)
# DATABASE_URL="postgresql://usuario:contraseña@dpg-xxxxx-a.oregon-postgres.render.com/historias_clinicas"

# ============================================
# CONFIGURACIÓN JWT
# ============================================
# Genera una clave secreta segura. Puedes usar: openssl rand -base64 32
JWT_SECRET=tu-clave-secreta-super-segura-cambiar-en-produccion-2024
JWT_EXPIRES_IN=24h

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# URL DEL FRONTEND (para CORS)
# ============================================
FRONTEND_URL=http://localhost:3001

# Sitio web público (CORS adicional, separado por coma)
# PUBLIC_SITE_URL=http://localhost:5173

# Turnos online públicos
PUBLIC_TURNOS_SLOT_MINUTOS=20
PUBLIC_TURNOS_ANTICIPACION_MIN_HORAS=2
PUBLIC_TURNOS_ANTICIPACION_MAX_DIAS=60
# Días: 0=domingo … 6=sábado (1-5 = lun–vie)
PUBLIC_TURNOS_DIAS=1,2,3,4,5
PUBLIC_TURNOS_FRANJAS=09:00-13:00,16:00-20:00
PUBLIC_TURNOS_RATE_LIMIT_MAX=5
PUBLIC_TURNOS_RATE_LIMIT_WINDOW_MIN=60
CONSULTORIO_DIRECCION=Av. José Altube 2085, José C. Paz




